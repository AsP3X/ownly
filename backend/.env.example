# Database
DATABASE_URL=postgres://ownly:ownly@postgres:5432/ownly

# Backend secrets (auto-generated by init-env.sh if left as GENERATE_ME)
JWT_SECRET=GENERATE_ME
SETUP_TOKEN=GENERATE_ME
SIGNING_SECRET=GENERATE_ME

# Object Storage (Nebular OS)
OBJECT_STORAGE_JWT_SECRET=GENERATE_ME
STORAGE_MODE=proxy
OBJECT_STORAGE_URL=http://object-storage:9000
OBJECT_STORAGE_PUBLIC_URL=http://localhost:9000
OBJECT_STORAGE_BUCKET=media

# Misc
URL_EXPIRY_SECONDS=3600
RUST_LOG=info
BIND_ADDR=0.0.0.0:3000
OWNLY_ENVIRONMENT=development
MAX_UPLOAD_BYTES=10737418240
# Per-user upload requests per minute (default 180).
UPLOAD_RPM=1200
# Optional GPU HLS ingest: auto | off | nvenc | vaapi | qsv
HLS_HARDWARE_ENCODE=auto
# Linux VAAPI/QSV device node when using vaapi/qsv or auto on Intel/AMD hosts
HLS_VAAPI_DEVICE=/dev/dri/renderD128
