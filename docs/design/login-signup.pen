                                      "alignItems": "center",
                                      "children": [
                                        {
                                          "type": "icon",
                                          "id": "frjoc",
                                          "name": "File Icon",
                                          "width": 12,
                                          "height": 12,
                                          "icon": "file-text",
                                          "library": "lucide",
                                          "fill": "$accent-primary"
                                        },
                                        {
                                          "type": "text",
                                          "id": "tewkR",
                                          "name": "AES Label",
                                          "fill": "$text-primary",
                                          "content": "AES-256-GCM",
                                          "fontFamily": "Inter",
                                          "fontSize": 8.5,
                                          "fontWeight": "Bold"
                                        }
                                      ]
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "s6XKb",
                              "name": "Paragraph 2",
                              "fill": "$text-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Once derived, the Master Key is ingested by an HMAC-based Expand Key Derivation Function (HKDF) to yield separate keys for local authentication and localized file encryption. Files are encrypted block-by-block using AES-256-GCM. Ownly automatically provisions a unique 96-bit Initialization Vector (IV) and a 128-bit authentication tag for each transaction. This level of zero-knowledge hygiene ensures that the system is resilient against man-in-the-middle vector risks.",
                              "lineHeight": 1.4,
                              "fontFamily": "Inter",
                              "fontSize": 9.5,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "Mo0qM",
                              "name": "Security Note Callout",
                              "width": "fill_container",
                              "fill": "#EFF6FF",
                              "stroke": "$accent-primary",
                              "strokeWidth": {
                                "left": 4
                              },
                              "layout": "vertical",
                              "gap": 4,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "P8c40C",
                                  "name": "Callout Title",
                                  "fill": "$accent-primary",
                                  "content": "SECURITY NOTE: VOLATILE MEMORY ONLY",
                                  "fontFamily": "Inter",
                                  "fontSize": 8,
                                  "fontWeight": "Bold"
                                },
                                {
                                  "type": "text",
                                  "id": "SyQPJ",
                                  "name": "Callout Body",
                                  "fill": "$text-secondary",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Because all cryptographic material exists purely in the user's local volatile memory and is purged immediately after operations complete, Ownly's cloud servers never store, transit, or hold keys. Data is mathematically recovery-proof without local credentials.",
                                  "lineHeight": 1.3,
                                  "fontFamily": "Inter",
                                  "fontSize": 8,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
