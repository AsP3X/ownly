                            },
                            {
                              "type": "text",
                              "id": "KOZGm",
                              "name": "Paragraph 2 Part A",
                              "fill": "$text-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Once derived, the Master Key is ingested by an HMAC-based Expand Key Derivation Function (HKDF) to yield separate keys for local authentication and localized file encryption.",
                              "lineHeight": 1.4,
                              "fontFamily": "Inter",
                              "fontSize": 9.5,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "XSht2",
                              "name": "Highlighted Text Container",
                              "width": "fill_container",
                              "gap": 8,
                              "alignItems": "center",
                              "children": [
                                {
                                  "type": "frame",
                                  "id": "xBCkZ",
                                  "name": "Highlight Background",
                                  "width": "fill_container",
                                  "fill": "#FEF08A60",
                                  "cornerRadius": 4,
                                  "layout": "vertical",
                                  "padding": [
                                    4,
                                    8
                                  ],
                                  "children": [
                                    {
                                      "type": "text",
                                      "id": "KrpuH",
                                      "name": "Highlighted Text",
                                      "fill": "$text-primary",
                                      "textGrowth": "fixed-width",
                                      "width": "fill_container",
                                      "content": "Files are encrypted block-by-block using AES-256-GCM. Ownly automatically provisions a unique 96-bit Initialization Vector (IV) and a 128-bit authentication tag for each transaction.",
                                      "lineHeight": 1.4,
                                      "fontFamily": "Inter",
                                      "fontSize": 9.5,
                                      "fontWeight": "normal"
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "pNRom",
                              "name": "Paragraph 2 Part B",
                              "fill": "$text-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "This level of zero-knowledge hygiene ensures that the system is resilient against man-in-the-middle vector risks.",
                              "lineHeight": 1.4,
                              "fontFamily": "Inter",
                              "fontSize": 9.5,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "N6LUJA",
                              "name": "Security Note Callout",
                              "width": "fill_container",
                              "fill": "#EFF6FF",
                              "stroke": "$accent-primary",
                              "strokeWidth": {
                                "left": 4
                              },
                              "layout": "vertical",
                              "gap": 4,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "S0wcU",
                                  "name": "Callout Title",
                                  "fill": "$accent-primary",
                                  "content": "SECURITY NOTE: VOLATILE MEMORY ONLY",
                                  "fontFamily": "Inter",
                                  "fontSize": 8,
                                  "fontWeight": "Bold"
                                },
                                {
                                  "type": "text",
                                  "id": "SOI75",
                                  "name": "Callout Body",
                                  "fill": "$text-secondary",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Because all cryptographic material exists purely in the user's local volatile memory and is purged immediately after operations complete, Ownly's cloud servers never store, transit, or hold keys. Data is mathematically recovery-proof without local credentials.",
                                  "lineHeight": 1.3,
                                  "fontFamily": "Inter",
                                  "fontSize": 8,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
