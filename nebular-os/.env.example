# Nebular OS secrets (generate random values, each >= 32 characters)
NOS_JWT_SECRET=GENERATE_ME
NOS_SIGNING_SECRET=GENERATE_ME

# Server
NOS_BIND_ADDR=0.0.0.0:9000
NOS_DATA_DIR=./data/blobs
NOS_META_PATH=./data/meta/metadata.db

# Misc
# Max single-object PUT size in bytes (default 10 GiB when using MediaVault Compose).
NOS_MAX_BODY_SIZE=10737418240
NOS_UPLOAD_BUFFER_SIZE=262144
NOS_ALLOW_PUBLIC_READ=false
NOS_RECONCILE_ON_STARTUP=false
NOS_RECONCILE_INTERVAL_SECS=0
NOS_SOFT_DELETE_TTL_SECS=86400
NOS_SOFT_DELETE_DROP_BLOB=false
NOS_MULTIPART_UPLOAD_TTL_SECS=86400
NOS_RECOMPRESS_ON_STARTUP=false
NOS_RECOMPRESS_INTERVAL_SECS=0
NOS_RECOMPRESS_BATCH_SIZE=100
NOS_METRICS_TOKEN=
NOS_RATE_LIMIT_RPS=0
NOS_RATE_LIMIT_BURST=50
NOS_LIST_SCAN_CAP=4096
NOS_MULTIPART_PART_SIZE=8388608
NOS_READ_POOL_SIZE=4
NOS_CORS_ORIGINS=
RUST_LOG=info
