# Nebular OS secrets (generate random values, each >= 32 characters)
NOS_JWT_SECRET=GENERATE_ME
NOS_SIGNING_SECRET=GENERATE_ME

# Server
NOS_BIND_ADDR=0.0.0.0:9000
NOS_DATA_DIR=./data/blobs
NOS_META_PATH=./data/meta/metadata.db

# Misc
NOS_MAX_BODY_SIZE=104857600
NOS_UPLOAD_BUFFER_SIZE=262144
NOS_ALLOW_PUBLIC_READ=false
NOS_RECONCILE_ON_STARTUP=false
NOS_RECONCILE_INTERVAL_SECS=0
NOS_SOFT_DELETE_TTL_SECS=86400
NOS_SOFT_DELETE_DROP_BLOB=false
NOS_MULTIPART_UPLOAD_TTL_SECS=86400
NOS_RECOMPRESS_ON_STARTUP=false
NOS_RECOMPRESS_INTERVAL_SECS=0
NOS_RECOMPRESS_BATCH_SIZE=100
NOS_METRICS_TOKEN=
NOS_RATE_LIMIT_RPS=0
NOS_RATE_LIMIT_BURST=50
NOS_LIST_SCAN_CAP=4096
NOS_MULTIPART_PART_SIZE=8388608
NOS_READ_POOL_SIZE=4
NOS_ZSTD_LEVEL=3
NOS_S3_COMPAT=false
NOS_BUCKET_POLICY=
NOS_S3_ACCESS_KEY=
NOS_S3_SECRET_KEY=
NOS_CORS_ORIGINS=
RUST_LOG=info

# Cluster (optional — unset NOS_CLUSTER_MODE for standalone single-node behavior)
# NOS_CLUSTER_MODE=standalone
# NOS_NODE_ID=node-a
# NOS_INSTANCE_ID=node-a
# NOS_REGION_LABEL=
# NOS_CLUSTER_TOKEN=
# NOS_CLUSTER_PEERS=node-b=http://127.0.0.1:9001;default,hls-hot;group=default
# NOS_REPLICATION_ROLE=member
# NOS_REPLICATION_GROUP=default
# NOS_REPLICATION_FACTOR=1
# NOS_REPLICATION_READ_REPAIR=false
# NOS_REPLICATION_ASYNC=true
# NOS_STORAGE_CLASSES=default
# NOS_DEFAULT_STORAGE_CLASS=default
# NOS_ASSIGNMENT_RULES={"rules":[{"storage_class":"hls-hot","prefix":"users/","mime_prefix":"video/","assigned_node":"node-hot"}]}
# NOS_ASSIGNMENT_FORWARD=false
