# Database
DATABASE_URL=postgres://mediavault:mediavault@postgres:5432/mediavault
POSTGRES_USER=mediavault
POSTGRES_PASSWORD=mediavault
POSTGRES_DB=mediavault

# Backend secrets (auto-generated by init-env.sh if left as GENERATE_ME)
JWT_SECRET=GENERATE_ME
SIGNING_SECRET=GENERATE_ME

# Object Storage (Nebular OS)
NOS_JWT_SECRET=GENERATE_ME
NOS_SIGNING_SECRET=GENERATE_ME
OBJECT_STORAGE_URL=http://object-storage:9000
OBJECT_STORAGE_PUBLIC_URL=http://localhost:9000
OBJECT_STORAGE_BUCKET=media
STORAGE_MODE=proxy
# Optional Nebular OS space-saving tuning (defaults match docker-compose.yml)
NOS_SOFT_DELETE_DROP_BLOB=true
NOS_RECOMPRESS_ON_STARTUP=true
NOS_RECOMPRESS_INTERVAL_SECS=3600

# Misc
URL_EXPIRY_SECONDS=3600
RUST_LOG=info
BIND_ADDR=0.0.0.0:3000
MEDIAVAULT_ENVIRONMENT=development
# Max single-file upload size in bytes (default 10 GiB). Keep nginx and NOS_MAX_BODY_SIZE aligned.
MAX_UPLOAD_BYTES=10737418240
# Per-user upload requests per minute (default 180). Raise for large batch imports.
UPLOAD_RPM=180
# Optional: nginx proxy timeout for large uploads (default 1 hour).
# NGINX_PROXY_READ_TIMEOUT=3600s
