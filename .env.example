# Database
DATABASE_URL=postgres://ownly:ownly@postgres:5432/ownly
POSTGRES_USER=ownly
POSTGRES_PASSWORD=ownly
POSTGRES_DB=ownly

# Backend secrets (auto-generated by init-env.sh if left as GENERATE_ME)
JWT_SECRET=GENERATE_ME
SETUP_TOKEN=GENERATE_ME
SIGNING_SECRET=GENERATE_ME

# Object Storage (Nebular OS)
# NOS_SIGNING_SECRET must match what the API uses for presigned download URLs (init-env.sh syncs from SIGNING_SECRET).
NOS_JWT_SECRET=GENERATE_ME
NOS_SIGNING_SECRET=GENERATE_ME
OBJECT_STORAGE_URL=http://object-storage:9000
# Browser base for presigned downloads — must match how users reach the app (nginx proxies /media/ to Nebular).
# Local Compose: http://localhost:8080  Remote example: http://corespace.de:8089
OBJECT_STORAGE_PUBLIC_URL=http://localhost:8080
OBJECT_STORAGE_BUCKET=media
STORAGE_MODE=proxy
# Where object index metadata lives: nebular (default) | ownly (Postgres index in Ownly + optional Nebular postgres mode).
STORAGE_METADATA_MODE=nebular
# Optional Nebular OS space-saving tuning (defaults match docker-compose.yml; see docs/storage-disk-tuning.md)
NOS_SOFT_DELETE_DROP_BLOB=true
# false = fast Compose boot; true blocks HTTP until all blobs are scanned (slow on large volumes)
NOS_RECOMPRESS_ON_STARTUP=false
NOS_RECOMPRESS_INTERVAL_SECS=3600
NOS_RECOMPRESS_BATCH_SIZE=100
# Fast upload zstd (default 3) vs background/maintenance zstd (default 22)
NOS_ZSTD_LEVEL_UPLOAD=3
NOS_ZSTD_LEVEL=22
# Optional: NOS_ZSTD_DICT_ENABLED=false, NOS_DEDUP_ENABLED=false
# When STORAGE_METADATA_MODE=ownly, set on object-storage: NOS_METADATA_MODE=blob_only
# Bulk delete / upload backpressure (nebular-os v0.1.4+): NOS_BULK_DELETE_CONCURRENCY=32, NOS_BULK_DELETE_BATCH_LIMIT=1000, NOS_UPLOAD_MAX_IN_FLIGHT_BYTES=33554432

# SEC-002 security audit (optional — copy to .env for local probes; never commit real passwords)
# One admin + bootstrap (creates/deletes temp subject): SEC002_BOOTSTRAP_SUBJECT=1
# SEC002_DEMOTER_EMAIL=your-admin@example.com
# SEC002_DEMOTER_PASSWORD=change-me
# Two admins (no bootstrap):
# SEC002_SUBJECT_EMAIL=admin-a@example.com
# SEC002_SUBJECT_PASSWORD=change-me
# SEC002_DEMOTER_EMAIL=admin-b@example.com
# SEC002_DEMOTER_PASSWORD=change-me
# SEC002_BASE_URL=http://127.0.0.1:8080

# SEC-003 security audit (folder share + soft-deleted file in public link)
# SEC003_OWNER_EMAIL=your-user@example.com
# SEC003_OWNER_PASSWORD=change-me
# SEC003_SHARE_PASSWORD=
# SEC003_BASE_URL=http://127.0.0.1:8080

# SEC-004 security audit (authenticated download after soft-delete)
# SEC004_OWNER_EMAIL=your-user@example.com
# SEC004_OWNER_PASSWORD=change-me
# SEC004_BASE_URL=http://127.0.0.1:8080

# SEC-005 security audit (unauthenticated setup bootstrap)
# SEC005_BASE_URL=http://127.0.0.1:8080

# SEC-012 security audit (LIVE exploit — initialized: JWT forgery + POST /admin/users)
# SEC012_CONFIRM_EXPLOIT=1
# SEC012_BASE_URL=http://127.0.0.1:8080
# SEC012_EXPLOIT_EMAIL=your-pro-user@example.com
# SEC012_EXPLOIT_PASSWORD=change-me-8chars-min
# SEC012_CREATED_ADMIN_EMAIL=my-audit-admin
# username-only values get @audit.invalid; omit for sec012-created-*@audit.invalid
# JWT_SECRET=...  (script reads this from .env — must match the running API)

# SEC-006 security audit (rate limit / forwarded headers)
# SEC006_BASE_URL=http://127.0.0.1:8080
# SEC006_LOGIN_RPM=15
# SEC006_REGISTER_RPM=5

# SEC-007 security audit (share overview password bypass)
# SEC007_OWNER_EMAIL=your-user@example.com
# SEC007_OWNER_PASSWORD=change-me
# SEC007_SHARE_PASSWORD=sec007-audit-pass
# SEC007_BASE_URL=http://127.0.0.1:8080

# SEC-008 security audit (setup storage test SSRF)
# SEC008_BASE_URL=http://127.0.0.1:8080

# SEC-009 security audit (share password brute-force throttling)
# SEC009_OWNER_EMAIL=your-user@example.com
# SEC009_OWNER_PASSWORD=change-me
# SEC009_SHARE_PASSWORD=sec009-audit-pass
# SEC009_WRONG_ATTEMPTS=12
# SEC009_BASE_URL=http://127.0.0.1:8080

# SEC-010 security audit (setup database test internal Postgres probing)
# SEC010_BASE_URL=http://127.0.0.1:8080

# SEC-011 security audit (trash files in folder/bulk zip archives)
# SEC011_OWNER_EMAIL=your-user@example.com
# SEC011_OWNER_PASSWORD=change-me
# SEC011_BASE_URL=http://127.0.0.1:8080

# Misc
URL_EXPIRY_SECONDS=3600
RUST_LOG=info
BIND_ADDR=0.0.0.0:3000
OWNLY_ENVIRONMENT=development
# Max single-file upload size in bytes (default 10 GiB). Keep nginx and NOS_MAX_BODY_SIZE aligned.
MAX_UPLOAD_BYTES=10737418240
# Per-user upload requests per minute (default 180). Raise for large batch imports.
UPLOAD_RPM=600
# Max parallel Nebular PUT HTTP calls from the API (default 2). Lower if bulk uploads hit storage 500s.
STORAGE_PUT_MAX_CONCURRENT=2
# Optional GPU HLS ingest: auto | off | nvenc | vaapi | qsv
HLS_HARDWARE_ENCODE=auto
HLS_VAAPI_DEVICE=/dev/dri/renderD128
# HLS disk tuning — higher CRF/CQ = smaller encrypted segments (see docs/storage-disk-tuning.md)
HLS_VIDEO_CRF=20
HLS_VIDEO_QUALITY=22
HLS_FULL_TRANSCODE_QUALITY=26
HLS_LARGE_MAXRATE=5M
HLS_LARGE_BUFSIZE=10M
# Optional: nginx proxy timeout for large uploads (default 1 hour).
# NGINX_PROXY_READ_TIMEOUT=3600s
